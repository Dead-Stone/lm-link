# Copy to `.env` in the project root (gitignored):
#   cp .env.example .env
#
# Restart Metro after changing EXPO_PUBLIC_* variables.

# ── Dev tunnel (npm run start:tunnel) ────────────────────────────────────────
# Free token: https://ngrok.com
# NGROK_AUTHTOKEN=

# ── Hugging Face model library ─────────────────────────────────────────────────
# Read token: https://huggingface.co/settings/tokens
# Fallback when the user has not set a token in Settings → Connection → Advanced.
# Paste your token in `.env` only — never commit `.env` or put a real token here.
EXPO_PUBLIC_HF_TOKEN=

# Optional: backend proxy when you do not want a token in the client bundle.
# Your server attaches its HF token; the app calls this instead of huggingface.co.
# Example: https://api.example.com/v1/hf
# EXPO_PUBLIC_HF_PROXY_URL=

# Per-user HF token (optional override): Settings → Connection → Advanced keys.
