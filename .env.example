# Copy to `.env` in the project root (gitignored):
#   cp .env.example .env
#
# Restart Metro after changing EXPO_PUBLIC_* variables.

# ── Dev tunnel (npm run start:tunnel) ────────────────────────────────────────
# Free token: https://ngrok.com
# NGROK_AUTHTOKEN=

# ── Hugging Face model library ─────────────────────────────────────────────────
# Preferred: set a token in the app (Settings → Connection → Advanced keys).
# It is stored in SecureStore, not in AsyncStorage.
#
# Production / shared builds: use a backend proxy (no client token in the bundle).
# EXPO_PUBLIC_HF_PROXY_URL=https://api.example.com/v1/hf
#
# Dev-only fallback (__DEV__ builds only, ignored when a proxy URL is set):
# Read token: https://huggingface.co/settings/tokens
# Paste your token in `.env` only — never commit `.env` or put a real token here.
EXPO_PUBLIC_HF_TOKEN=

# Per-user HF token override: Settings → Connection → Advanced keys.
