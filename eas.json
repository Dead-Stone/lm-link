{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "RNLLAMA_SKIP_POSTINSTALL": "1",
        "EAS_FALLBACK_PACKAGE_MANAGER": "npm"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "RNLLAMA_SKIP_POSTINSTALL": "1",
        "EAS_FALLBACK_PACKAGE_MANAGER": "npm"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "RNLLAMA_SKIP_POSTINSTALL": "1",
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true",
        "EAS_FALLBACK_PACKAGE_MANAGER": "npm"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      }
    }
  }
}
