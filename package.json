{
  "name": "lm-link",
  "version": "1.0.0",
  "packageManager": "npm@11.12.1",
  "license": "MIT",
  "main": "expo-router/entry",
  "dependencies": {
    "@expo-google-fonts/caveat": "^0.4.2",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo-google-fonts/roboto": "^0.4.3",
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@shopify/flash-list": "^2.3.1",
    "babel-preset-expo": "~54.0.10",
    "expo": "^54.0.35",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-blur": "~15.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-network": "~8.0.8",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "llama.rn": "^0.12.4",
    "lottie-react-native": "~7.3.1",
    "metro": "^0.83.1",
    "metro-config": "^0.83.1",
    "metro-runtime": "^0.83.1",
    "metro-source-map": "^0.83.1",
    "punycode": "^2.3.1",
    "react": "^19.1.0",
    "react-native": "^0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "react-native-zeroconf": "^0.14.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "canvas": "^3.2.3",
    "jsdom": "^29.1.1",
    "lottie-web": "^5.13.0",
    "patch-package": "^8.0.0",
    "sharp": "^0.34.5",
    "simple-icons": "^16.23.0",
    "typescript": "^5.9.3"
  },
  "expo": {
    "install": {
      "exclude": [
        "@shopify/flash-list"
      ]
    }
  },
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start --lan",
    "start:localhost": "expo start --localhost",
    "start:tunnel": "node scripts/start-tunnel.mjs --clear",
    "android": "bash scripts/run-android.sh",
    "ios": "expo run:ios",
    "install-llama-rn": "node scripts/install-llama-rn.js",
    "compose-brand-icons": "node scripts/compose-brand-icons.mjs",
    "compose-play-feature-graphic": "node scripts/compose-play-feature-graphic.mjs",
    "compose-readme-hero": "node scripts/compose-readme-hero.mjs",
    "compose:assets": "npm run compose-brand-icons && npm run compose-readme-hero",
    "prepare-build-assets": "npm run compose:assets && npx expo prebuild --platform android --no-install",
    "sync-brand-logos": "node scripts/sync-brand-logos.mjs",
    "eas-build-post-install": "node scripts/install-llama-rn.js && node scripts/write-android-local-properties.js && npm run compose:assets",
    "build:apk:local": "bash scripts/build-android-local.sh preview",
    "build:apk:local:debug": "bash scripts/build-android-local.sh development",
    "build:aab": "EAS_BUILD_NO_EXPO_GO_WARNING=true eas build --platform android --profile production",
    "build:aab:local": "EAS_BUILD_NO_EXPO_GO_WARNING=true bash scripts/build-android-local.sh production"
  },
  "private": true
}
